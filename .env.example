# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Generate a strong random string for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-production

# JWT access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── C++ Vitals Binary ─────────────────────────────────────────────────────────
# Path to the compiled C++ binary (stub or real Presage SDK binary).
# Compile the stub first: cd cpp && g++ -O2 -o vitals_stub vitals_binary_stub.cpp
CPP_BINARY_PATH=./cpp/vitals_stub

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path. Change to a PostgreSQL URL for production.
DB_URL=sqlite:///./biofeedback.db

# ── Vitals Downsampling ───────────────────────────────────────────────────────
# How often (in seconds) a MetricSample row is written to the DB during a session.
# The C++ binary produces one reading/sec; this controls DB storage granularity.
DOWNSAMPLE_INTERVAL_SECONDS=5
