# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Generate a strong random string for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-production

# JWT access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path. Change to a PostgreSQL URL for production.
DB_URL=sqlite:///./notstressed.db

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# Required for POST /tasks/analyze and POST /tasks
OPENAI_API_KEY=sk-your-key-here
